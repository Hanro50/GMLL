{
  // Change this to match your project
  "exclude": ["node_modules", "dist"],
  "include": ["src/**/*"],
  "compilerOptions": {
    "outDir": "dist",
    "moduleResolution": "Node16",
    "resolveJsonModule": true,
    "target": "es2021",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "importHelpers": true,
    "esModuleInterop": true,
    "removeComments": false,
    "declaration": true,
    "declarationDir": "types",
    "rootDir": "src/",
    "module": "Node16"
  }
}
